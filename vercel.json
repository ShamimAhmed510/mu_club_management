{
  "version": 2,
  "public": true,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "index.ts", 
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/club-portal/package.json",
      "use": "@vercel/static-build",
      "config": { 
        "distDir": "dist/public" 
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "artifacts/club-portal/assets/$1",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/club-portal/$1",
      "continue": true
    }
  ]
}

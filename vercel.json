{
  "version": 2,
  "public": true,
  "installCommand": "corepack enable && pnpm install",
  "builds": [
    { "src": "index.ts", "use": "@vercel/node" },
    {
      "src": "artifacts/club-portal/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "index.ts" },
    { "src": "/assets/(.*)", "dest": "artifacts/club-portal/assets/$1" },
    { "src": "/(.*)", "dest": "artifacts/club-portal/$1", "continue": true }
  ]
}
